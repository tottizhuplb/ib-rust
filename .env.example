# =============================================================================
# 复制为 .env 后修改：cp .env.example .env
# docker-compose 从此文件读取配置（ib-gateway / rust-engine 共用 env_file: .env）
# =============================================================================

# --- IB Gateway（gnzsnz/ib-gateway-docker）---
# https://github.com/gnzsnz/ib-gateway-docker

# IB 登录账号（必填）
TWS_USERID=
TWS_PASSWORD=
# VNC 密码（2FA 需设置，连接 127.0.0.1:5900；留空则不开 VNC）
VNC_SERVER_PASSWORD=

# --- 以下为默认值，一般无需修改 ---
TRADING_MODE=paper
TWS_ACCEPT_INCOMING=accept
READ_ONLY_API=no
TWOFA_TIMEOUT_ACTION=restart
# 按 TIME_ZONE（UTC）解析；11:59 AM UTC = 香港 19:59
AUTO_RESTART_TIME=11:59 AM
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
EXISTING_SESSION_DETECTED_ACTION=primary
ALLOW_BLIND_TRADING=no
TIME_ZONE=Etc/UTC
TZ=Etc/UTC
TWS_SETTINGS_PATH=/home/ibgateway/tws_settings
