FROM rust:1-bookworm

WORKDIR /app

ENV PATH="/usr/local/cargo/bin:${PATH}"

# login shell（docker exec bash -l / 部分 IDE attach）会读 /etc/profile 并重置 PATH
RUN printf '%s\n' 'export PATH="/usr/local/cargo/bin:$PATH"' > /etc/profile.d/cargo.sh

RUN rustup component add rustfmt \
    && cargo install cargo-watch

# Pre-fetch dependencies so first `cargo run` is faster (source is mounted at runtime).
COPY Cargo.toml ./
RUN mkdir src \
    && echo "fn main() {}" > src/main.rs \
    && cargo fetch \
    && rm -rf src

# 开发容器保持运行，进容器后手动 cargo run / cargo watch -x run
CMD ["sleep", "infinity"]
